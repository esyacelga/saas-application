# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gym-app-saas
DB_USER=tu_usuario_db
DB_PASSWORD=tu_password_db

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8080

# ── JWT ───────────────────────────────────────────────────────────────────────
# Mínimo 256 bits. Generar con: openssl rand -base64 32
JWT_SECRET=cambia-este-valor-en-produccion-minimo-256-bits
JWT_EXPIRY_STAFF=28800       # 8 horas en segundos
JWT_EXPIRY_CLIENTE=604800    # 7 días en segundos
JWT_REFRESH_EXPIRY=2592000   # 30 días en segundos

# ── Seguridad ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PWD_RESET_TOKEN_EXPIRY_HOURS=1

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Para Gmail usar una App Password (no la contraseña de la cuenta)
# Activar en: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password_gmail

# ── Frontend / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_ALL=true

# ── Cloudinary (subida de fotos de operadores) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
