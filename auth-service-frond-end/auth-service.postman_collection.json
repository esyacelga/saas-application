  "item": [
    {
      "name": "🔐 Autenticación",
      "item": [
        {
          "name": "Login Plataforma (super_admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('platform_token', body.access_token);",
                  "  pm.collectionVariables.set('refresh_token', body.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/platform/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"root@gym-admin.local\",\n  \"password\": \"seya1922\"\n}"
            }
          }
        },
        {
          "name": "Login Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('staff_token', body.access_token);",
                  "  pm.collectionVariables.set('refresh_token', body.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
