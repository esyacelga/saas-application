      "item": [
        {
          "name": "Consultar Bitácora (sin filtros)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staff_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/bitacora?pagina=1&limit=50",
              "host": ["{{base_url}}"],
              "path": ["bitacora"],
              "query": [
                { "key": "pagina", "value": "1" },
                { "key": "limit",  "value": "50" }
              ]
            }
          }
        },
        {
          "name": "Consultar Bitácora (con filtros)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{staff_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/bitacora?modulo=seguridad&desde=2026-05-01T00:00:00Z&hasta=2026-05-31T23:59:59Z&idUsuario=42&pagina=1&limit=50",
              "host": ["{{base_url}}"],
              "path": ["bitacora"],
              "query": [
                { "key": "modulo",     "value": "seguridad" },
                { "key": "desde",      "value": "2026-05-01T00:00:00Z" },
                { "key": "hasta",      "value": "2026-05-31T23:59:59Z" },
