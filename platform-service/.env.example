# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gym_administrator
DB_USER=gym_user
DB_PASSWORD=gym_pass

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Clave en Base64 de al menos 256 bits.  Cambia este valor en producción.
JWT_SECRET=Y2hhbmdlLW1lLWluLXByb2R1Y3Rpb24tdGhpcy1rZXktbXVzdC1iZS0yNTYtYml0cw==

# ── Configuración del módulo check ────────────────────────────────────────────
MODULE_CHECK_CACHE_TTL_SECONDS=300

# ── QR Token ──────────────────────────────────────────────────────────────────
QR_TOKEN_LENGTH=32

# ── Cron de suscripciones ─────────────────────────────────────────────────────
# Formato cron: segundo minuto hora día mes díaSemana
SUBSCRIPTION_JOB_CRON=0 5 0 * * *

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_ALL=true

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────────────
# Sin META_ACCESS_TOKEN/META_PHONE_NUMBER_ID el servicio arranca igual y omite los envíos (dev/CI).
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
# Idioma de las plantillas HSM. Debe coincidir EXACTO con el idioma aprobado en Business Manager:
# Meta indexa por el par (nombre, idioma) y responde 404 code=132001 si ese par no existe.
# Spanish (ECU) → es_EC. NO uses `es` a secas si la plantilla se dio de alta como es_EC.
WHATSAPP_TEMPLATE_LANG=es_EC

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
