# Database
DB_URL=r2dbc:postgresql://localhost:5432/gymadmin
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT (shared secret with all services — Base64-encoded, min 256 bits)
JWT_SECRET=

# CORS
CORS_ORIGINS=http://localhost:5173
CORS_ALLOW_ALL=false

# SRI Electronic Invoicing
SRI_AMBIENTE=1
SRI_WSDL_RECEPCION=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/RecepcionComprobantesOffline?wsdl
SRI_WSDL_AUTORIZACION=https://celcer.sri.gob.ec/comprobantes-electronicos-ws/AutorizacionComprobantesOffline?wsdl
SRI_STORAGE_PATH=./storage/sri

# P12 certificate AES-256-GCM encryption key (Base64-encoded 32 bytes)
CERT_ENCRYPTION_KEY=
